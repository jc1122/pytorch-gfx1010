+template <typename InputIteratorT>
+__global__ void unique_flags_kernel(
+    int64_t n,
+    InputIteratorT input,
+    int* output) {
+  CUDA_KERNEL_LOOP(i, n) {
+    output[i] = i == 0 || input[i] != input[i - 1];
+  }
+}
+
+__global__ void unique_counts_kernel(
+    int64_t n,
+    const int64_t* unique_indices,
+    int64_t num_inp,
+    int64_t* counts) {
+  CUDA_KERNEL_LOOP(i, n) {
+    const int64_t next = i + 1 < n ? unique_indices[i + 1] : num_inp;
+    counts[i] = next - unique_indices[i];
+  }
+}
+
+__global__ void unique_inverse_kernel(
+    int64_t n,
+    const int64_t* unique_indices,
+    int64_t num_unique,
+    const int64_t* sorted_indices,
+    bool scatter_to_input_order,
+    int64_t* inverse_indices) {
+  CUDA_KERNEL_LOOP(i, n) {
+    int64_t left = 0;
+    int64_t right = num_unique;
+    while (left < right) {
+      const int64_t mid = left + (right - left) / 2;
+      if (unique_indices[mid] <= i) {
+        left = mid + 1;
+      } else {
+        right = mid;
+      }
+    }
+    const int64_t out_index = scatter_to_input_order ? sorted_indices[i] : i;
+    inverse_indices[out_index] = left - 1;
+  }
+}
