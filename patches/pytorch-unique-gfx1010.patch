+__global__ void unique_counts_kernel(
+    int64_t n,
+    const int64_t* unique_indices,
+    int64_t num_inp,
+    int64_t* counts) {
+  int64_t i = threadIdx.x + static_cast<int64_t>(blockIdx.x) * blockDim.x;
+  int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;
+  for (; i < n; i += stride) {
+    const int64_t next = i + 1 < n ? unique_indices[i + 1] : num_inp;
+    counts[i] = next - unique_indices[i];
+  }
+}
+
+__global__ void unique_dim_inverse_kernel(
+    int64_t n,
+    const int64_t* unique_positions,
+    int64_t num_unique,
+    const int64_t* indices,
+    int64_t* inverse_indices) {
+  int64_t i = threadIdx.x + static_cast<int64_t>(blockIdx.x) * blockDim.x;
+  int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;
+  for (; i < n; i += stride) {
+    int64_t left = 0;
+    int64_t right = num_unique;
+    while (left < right) {
+      const int64_t mid = left + (right - left) / 2;
+      if (unique_positions[mid] <= i) {
+        left = mid + 1;
+      } else {
+        right = mid;
+      }
+    }
+    inverse_indices[indices[i]] = left - 1;
+  }
+}
+
+template <typename scalar_t>
+__global__ void row_unique_flags_kernel(
+    int64_t num_rows,
+    int64_t row_width,
+    const scalar_t* input_flat,
+    const int64_t* indices,
+    int* flags) {
+  int64_t row = threadIdx.x + static_cast<int64_t>(blockIdx.x) * blockDim.x;
+  int64_t stride = static_cast<int64_t>(blockDim.x) * gridDim.x;
+  for (; row < num_rows; row += stride) {
+    bool unique = row == 0;
+    if (!unique) {
+      const int64_t curr = indices[row];
+      const int64_t prev = indices[row - 1];
+      unique = true;
+      for (int64_t col = 0; col < row_width; ++col) {
+        const scalar_t lhs = c10::load(&input_flat[col + curr * row_width]);
+        const scalar_t rhs = c10::load(&input_flat[col + prev * row_width]);
+        if (lhs != rhs) {
+          break;
+        }
+        if (col + 1 == row_width) {
+          unique = false;
+        }
+      }
+    }
+    flags[row] = unique;
+  }
+}
