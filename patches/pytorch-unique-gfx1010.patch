+template <typename scalar_t>
+std::tuple<Tensor, Tensor, Tensor, int64_t> compute_unique_dim_gfx1010(
+    const Tensor& input_flat,
+    const Tensor& indices,
+    const bool return_inverse,
+    const bool return_counts) {
+  const int64_t num_inp = indices.numel();
+  const int64_t row_width = input_flat.size(1);
+  const scalar_t* input_flat_ptr = input_flat.const_data_ptr<scalar_t>();
+  const int64_t* indices_ptr = indices.const_data_ptr<int64_t>();
+  auto long_options = indices.options();
+  auto int_options = indices.options().dtype(kInt);
+  cudaStream_t stream = at::cuda::getCurrentCUDAStream();
+
+  Tensor flags = at::empty({num_inp}, int_options);
+  constexpr int nthreads = 256;
+  const int64_t nblocks =
+      std::min<int64_t>(4096, (num_inp + nthreads - 1) / nthreads);
+  row_unique_flags_kernel<<<nblocks, nthreads, 0, stream>>>(
+      num_inp,
+      row_width,
+      input_flat_ptr,
+      indices_ptr,
+      flags.mutable_data_ptr<int>());
+  C10_CUDA_KERNEL_LAUNCH_CHECK();
+
+  Tensor unique_positions = at::nonzero(flags).view({-1});
+  const int64_t num_out = unique_positions.numel();
+  Tensor unique_indices = indices.index_select(0, unique_positions);
+
+  Tensor inverse_indices = at::empty({0}, long_options);
+  if (return_inverse) {
+    inverse_indices = at::empty({num_inp}, long_options);
+    unique_dim_inverse_kernel<<<nblocks, nthreads, 0, stream>>>(
+        num_inp,
+        unique_positions.const_data_ptr<int64_t>(),
+        num_out,
+        indices_ptr,
+        inverse_indices.mutable_data_ptr<int64_t>());
+    C10_CUDA_KERNEL_LAUNCH_CHECK();
+  }
+
+  Tensor counts = at::empty({0}, long_options);
+  if (return_counts) {
+    counts = at::empty({num_out}, long_options);
+    if (num_out > 0) {
+      unique_counts_kernel<<<nblocks, nthreads, 0, stream>>>(
+          num_out,
+          unique_positions.const_data_ptr<int64_t>(),
+          num_inp,
+          counts.mutable_data_ptr<int64_t>());
+      C10_CUDA_KERNEL_LAUNCH_CHECK();
+    }
+  }
+
+  return std::make_tuple(unique_indices, inverse_indices, counts, num_out);
+}
