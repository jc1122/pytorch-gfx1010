+template <typename scalar_t>
+std::tuple<Tensor, Tensor, Tensor> compute_unique_gfx1010(
+    const Tensor& sorted,
+    const Tensor& sorted_indices,
+    const bool return_inverse,
+    const bool return_counts,
+    const bool consecutive,
+    const IntArrayRef inverse_sizes) {
+  const int64_t num_inp = sorted.numel();
+  auto long_options = sorted.options().dtype(kLong);
+  auto int_options = sorted.options().dtype(kInt);
+  auto data = wrap_input_iterator(sorted.const_data_ptr<scalar_t>());
+  cudaStream_t stream = at::cuda::getCurrentCUDAStream();
+
+  Tensor flags = at::empty({num_inp}, int_options);
+  const dim3 block =
+      dim3(std::min(static_cast<int64_t>(cuda::getApplyBlock().x), num_inp));
+  dim3 grid;
+  c10::DeviceIndex curDevice = -1;
+  c10::cuda::GetDevice(&curDevice);
+  cuda::getApplyGrid(num_inp, grid, curDevice);
+  unique_flags_kernel<<<grid, block, 0, stream>>>(
+      num_inp, data, flags.mutable_data_ptr<int>());
+  C10_CUDA_KERNEL_LAUNCH_CHECK();
+
+  Tensor unique_indices = at::nonzero(flags).view({-1});
+  const int64_t num_out = unique_indices.numel();
+  Tensor data_out = sorted.index_select(0, unique_indices);
+
+  Tensor inverse_indices;
+  if (!return_inverse) {
+    inverse_indices = at::empty({0}, long_options);
+  } else {
+    inverse_indices = at::empty(inverse_sizes, long_options);
+    TORCH_INTERNAL_ASSERT(
+        consecutive || sorted_indices.defined(),
+        "return_inverse is set to true, but sorted_indices is undefined. Send a bug report!");
+    unique_inverse_kernel<<<grid, block, 0, stream>>>(
+        num_inp,
+        unique_indices.const_data_ptr<int64_t>(),
+        num_out,
+        consecutive ? nullptr : sorted_indices.const_data_ptr<int64_t>(),
+        !consecutive,
+        inverse_indices.mutable_data_ptr<int64_t>());
+    C10_CUDA_KERNEL_LAUNCH_CHECK();
+  }
+
+  Tensor counts = at::empty({0}, long_options);
+  if (return_counts) {
+    counts = at::empty({num_out}, long_options);
+    if (num_out > 0) {
+      unique_counts_kernel<<<grid, block, 0, stream>>>(
+          num_out,
+          unique_indices.const_data_ptr<int64_t>(),
+          num_inp,
+          counts.mutable_data_ptr<int64_t>());
+      C10_CUDA_KERNEL_LAUNCH_CHECK();
+    }
+  }
+
+  return std::tuple<Tensor, Tensor, Tensor>(
+      data_out, inverse_indices, counts);
+}
+
+template <typename scalar_t>
+std::tuple<Tensor, Tensor, Tensor> unique_gfx1010(
+    const Tensor& self,
+    const bool consecutive,
+    const bool return_inverse,
+    const bool return_counts) {
+  const int64_t num_inp = self.numel();
+  Tensor sorted;
+  Tensor sorted_indices;
+  if (consecutive) {
+    sorted = self.reshape({num_inp});
+  } else {
+    auto sorted_tuple = self.reshape({num_inp}).sort();
+    sorted = std::get<0>(sorted_tuple);
+    if (return_inverse) {
+      sorted_indices = std::get<1>(sorted_tuple);
+    }
+  }
+
+  return compute_unique_gfx1010<scalar_t>(
+      sorted,
+      sorted_indices,
+      return_inverse,
+      return_counts,
+      consecutive,
+      self.sizes());
+}
